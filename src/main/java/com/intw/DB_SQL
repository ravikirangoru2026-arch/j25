1) Show Duplicate Records with Duplication Count:
SELECT email, COUNT(*) AS duplicate_count
FROM employee
GROUP BY email
HAVING COUNT(*) > 1;


2) Show Full Duplicate Rows: email
SELECT *
FROM employee
WHERE email IN (
    SELECT email
    FROM employee
    GROUP BY email
    HAVING COUNT(*) > 1
);

3) Remove Duplicate Records: Assume duplicates based on email, keeping lowest id.

DELETE e1
FROM employee e1
JOIN employee e2
ON e1.email = e2.email
AND e1.id > e2.id;

*** Explanation
    Deletes duplicate rows
    Keeps the smallest id


1) Find Employees With Their Manager (Self Join)
SELECT e.name AS employee, m.name AS manager
FROM employee e
LEFT JOIN employee m
ON e.manager_id = m.id;

2) Find Employees Who Earn More Than Their Manager
SELECT e.name, e.salary
FROM employee e
JOIN employee m
ON e.manager_id = m.id
WHERE e.salary > m.salary;

3) Find the Nth Highest Salary
SELECT salary
FROM (
    SELECT salary,
           DENSE_RANK() OVER (ORDER BY salary DESC) AS rnk
    FROM employee
) t
WHERE rnk = 3;

4) Find Employees Who Joined in the Last 30 Days
SELECT *
FROM employee
WHERE join_date >= CURRENT_DATE - INTERVAL '30 DAY';

5) Find Customers Who Placed the Most Orders
SELECT customer_id, COUNT(*) AS total_orders
FROM orders
GROUP BY customer_id
ORDER BY total_orders DESC
LIMIT 1;

6) Find Duplicate Records
SELECT email, COUNT(*)
FROM users
GROUP BY email
HAVING COUNT(*) > 1;

7) Delete Duplicate Records
DELETE FROM users
WHERE id NOT IN (
   SELECT MIN(id)
   FROM users
   GROUP BY email
);




